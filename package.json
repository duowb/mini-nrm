{
  "name": "@fixpkg/mini-nrm",
  "type": "module",
  "version": "1.0.0",
  "description": "Mini npm registry manager",
  "author": "duowb <duowenbo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/duowb/mini-nrm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duowb/mini-nrm.git"
  },
  "bugs": {
    "url": "https://github.com/duowb/mini-nrm/issues"
  },
  "keywords": [
    "npm",
    "registry",
    "toggle",
    "manager",
    "mirror"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.cts",
      "require": "./dist/main.cjs"
    }
  },
  "main": "dist/main.cjs",
  "types": "dist/main.d.cts",
  "bin": {
    "mnrm": "dist/cli.cjs",
    "mimi-nrm": "dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest",
    "lint": "eslint",
    "release": "bumpp",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^7.8.4",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "prettier": "@sxzz/prettier-config"
}
